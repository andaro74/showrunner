{
  "permissions": {
    "allow": [
      "Bash(ruff check *)",
      "Bash(git check-ignore *)",
      "Bash(uv run *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python .claude/hooks/check_on_save.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python .claude/hooks/block_secrets.py"
          }
        ]
      }
    ]
  }
}
