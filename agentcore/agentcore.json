{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "showrunnerAgentcore",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "showrunnerAgentcore"
  },
  "runtimes": [
    {
      "name": "TvmazeMcp",
      "build": "CodeZip",
      "entrypoint": "mcp_servers/serve_tvmaze.py",
      "codeLocation": "./",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "instrumentation": {
        "enableOtel": false
      },
      "protocol": "MCP"
    },
    {
      "name": "PlacesMcp",
      "build": "CodeZip",
      "entrypoint": "mcp_servers/serve_places.py",
      "codeLocation": "./",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "instrumentation": {
        "enableOtel": false
      },
      "protocol": "MCP"
    }
  ],
  "memories": [
    {
      "name": "ShowRunnerMemory",
      "eventExpiryDuration": 30,
      "strategies": [
        {
          "type": "SEMANTIC",
          "namespaceTemplates": [
            "/users/{actorId}/facts"
          ]
        },
        {
          "type": "SUMMARIZATION",
          "namespaceTemplates": [
            "/summaries/{actorId}/{sessionId}"
          ]
        },
        {
          "type": "USER_PREFERENCE",
          "namespaceTemplates": [
            "/users/{actorId}/preferences"
          ]
        }
      ]
    }
  ],
  "knowledgeBases": [],
  "credentials": [],
  "evaluators": [
    {
      "name": "ShowRunnerQuality",
      "level": "SESSION",
      "config": {
        "llmAsAJudge": {
          "model": "us.anthropic.claude-sonnet-5",
          "instructions": "Evaluate whether the agent fulfilled the user's request. Context: {context}",
          "ratingScale": {
            "numerical": [
              {
                "value": 1,
                "label": "Poor",
                "definition": "Fails to meet expectations"
              },
              {
                "value": 2,
                "label": "Fair",
                "definition": "Partially meets expectations"
              },
              {
                "value": 3,
                "label": "Good",
                "definition": "Meets expectations"
              },
              {
                "value": 4,
                "label": "Very Good",
                "definition": "Exceeds expectations"
              },
              {
                "value": 5,
                "label": "Excellent",
                "definition": "Far exceeds expectations"
              }
            ]
          }
        }
      }
    }
  ],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [
    {
      "name": "showrunner-gateway",
      "protocolType": "None",
      "description": "Gateway for showrunner-gateway",
      "targets": [
        {
          "name": "TvmazeTarget",
          "targetType": "httpRuntime",
          "httpRuntime": {
            "runtime": "TvmazeMcp"
          }
        },
        {
          "name": "PlacesTarget",
          "targetType": "httpRuntime",
          "httpRuntime": {
            "runtime": "PlacesMcp"
          }
        }
      ],
      "authorizerType": "CUSTOM_JWT",
      "authorizerConfiguration": {
        "customJwtAuthorizer": {
          "discoveryUrl": "https://cognito-idp.us-west-2.amazonaws.com/us-west-2_EXAMPLE01/.well-known/openid-configuration",
          "allowedAudience": [
            "exampleuserclientid0000001"
          ]
        }
      },
      "enableSemanticSearch": true,
      "exceptionLevel": "NONE"
    }
  ],
  "policyEngines": [],
  "configBundles": [],
  "abTests": [],
  "harnesses": [],
  "datasets": [],
  "payments": []
}