# Secrets (local environment files are never committed)
.env.local

# CDK Build Artifacts
cdk/cdk.out/
cdk/node_modules/

# CLI Internals
.cli/*

# Ephemeral Staging
.cache/*

# deployed-state.json stays UNTRACKED on purpose. The CLI regenerates it on
# deploy, and it inventories live infrastructure — account ID, gateway URL, the
# three runtime IAM role names, memory ID, and the Secrets Manager ARN backing
# the gateway's OAuth client secret. That is targeted-reconnaissance material in
# a public repo, and nothing in the build needs it committed.

# Generated by `uv run scripts/config.py render`. The tracked source of truth is
# agentcore.template.json (placeholders) + policies/**/*.cedar; local-config.json
# holds this deployment's real account / pool / client / gateway ids.
agentcore.json
local-config.json
.rendered/
