# ShowRunner environment variables
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# this `.env.example` IS committed, so it must contain PLACEHOLDERS ONLY —
# never paste real secrets here.

# --- OpenStreetMap (Nominatim / Overpass / OSRM) ---
# REQUIRED. A descriptive User-Agent identifying this app + a contact address.
# OSM's public endpoints will rate-limit or block requests without one.
# See https://operations.osmfoundation.org/policies/nominatim/
OSM_USER_AGENT="showrunner/0.1 (you@example.com)"

# --- AWS / Amazon Bedrock ---
# Standard AWS SDK credentials. Prefer a shared profile or an IAM role over
# putting long-lived keys here; these are for local dev only.
AWS_REGION="us-east-1"
AWS_PROFILE="default"
# Only if not using a profile/role:
# AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
# AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
# Bedrock model used by the agents.
BEDROCK_MODEL_ID="us.anthropic.claude-sonnet-5-20250929-v1:0"

# --- Amazon Cognito (AgentCore Identity — inbound JWT) ---
# Cognito is the OAuth provider behind AgentCore Identity. The inbound JWT's
# `sub` claim scopes memory per real user (anti-impersonation).
COGNITO_USER_POOL_ID="us-east-1_xxxxxxxxx"
COGNITO_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxx"
COGNITO_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Issuer / discovery URL for token validation.
COGNITO_ISSUER="https://cognito-idp.us-east-1.amazonaws.com/us-east-1_xxxxxxxxx"

# --- Amazon Bedrock AgentCore Memory ---
# Long-term memory store for genre preferences and remembered picks,
# short-term memory for the active session.
AGENTCORE_MEMORY_ID="mem-xxxxxxxxxxxxxxxxxxxx"
AGENTCORE_MEMORY_ROLE_ARN="arn:aws:iam::123456789012:role/AgentCoreMemoryRole"
