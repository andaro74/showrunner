# ShowRunner environment variables
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# this `.env.example` IS committed, so it must contain PLACEHOLDERS ONLY —
# never paste real secrets here.

# --- OpenStreetMap (Nominatim / Overpass / OSRM) ---
# REQUIRED. A descriptive User-Agent identifying this app + a contact address.
# OSM's public endpoints will rate-limit or block requests without one.
# See https://operations.osmfoundation.org/policies/nominatim/
OSM_USER_AGENT="showrunner/0.1 (you@example.com)"

# --- AWS / Amazon Bedrock ---
# Standard AWS SDK credentials. Prefer a shared profile or an IAM role over
# putting long-lived keys here; these are for local dev only.
AWS_REGION="us-west-2"
AWS_PROFILE="default"
# Only if not using a profile/role:
# AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
# AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
# Bedrock model used by the agents.
BEDROCK_MODEL_ID="us.anthropic.claude-sonnet-4-6"

# --- Amazon Cognito (AgentCore Identity — inbound JWT) ---
# Cognito is the OAuth provider behind AgentCore Identity. The inbound JWT's
# `sub` claim scopes memory per real user (anti-impersonation).
COGNITO_USER_POOL_ID="us-west-2_xxxxxxxxx"
COGNITO_CLIENT_ID="xxxxxxxxxxxxxxxxxxxxxxxxxx"
COGNITO_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Issuer / discovery URL for token validation.
COGNITO_ISSUER="https://cognito-idp.us-west-2.amazonaws.com/us-west-2_xxxxxxxxx"
# Synthetic test user for invoking the deployed agent (see BUILD.md "Invoking
# the deployed ShowRunner agent"). Only ever a throwaway user you created with
# admin-create-user — NEVER a real person's credentials.
COGNITO_TEST_USERNAME="showrunner-tester"
COGNITO_TEST_PASSWORD="ChangeMe-Here-1!"

# --- MCP transport (stdio locally, HTTP when deployed) ---
# Servers default to stdio: the agent spawns them as private subprocesses, which
# is what local dev and the tests use. Leave these unset for that.
#
# Set MCP_TRANSPORT on a SERVER to run it standalone as its own AgentCore Runtime
# (--protocol MCP). The MCP protocol contract probes 0.0.0.0:8000/mcp — note 8000,
# not 8080 (8080 is the HTTP-protocol contract used by BedrockAgentCoreApp).
# The defaults are already correct, so MCP_HOST/MCP_PORT are usually unnecessary.
# MCP_TRANSPORT="streamable-http"   # stdio | sse | streamable-http
# MCP_HOST="0.0.0.0"
# MCP_PORT="8000"
#
# Specialist server URLs — usually UNNECESSARY. Resolution order per specialist:
# explicit env var below > the CLI-injected AGENTCORE_GATEWAY_<NAME>_URL (present
# on every deployed runtime, so deployed agents auto-wire to the Gateway) > stdio
# (local dev/tests). Set these only to force HTTP locally, e.g. against the
# deployed Gateway. Both specialists filter the Gateway's seven tools down to the
# set they own, so sharing one gateway URL cannot break the tool partition.
# TVMAZE_MCP_URL="https://<gateway-endpoint>/mcp"
# PLACES_MCP_URL="https://<gateway-endpoint>/mcp"
# Bearer token for LOCAL HTTP use only — when deployed, the caller's own JWT is
# forwarded per request instead. Must be an ACCESS token: it carries `client_id`,
# which is what `allowedClients` checks. An ID token carries `aud` and is rejected.
# MCP_BEARER_TOKEN="<cognito-access-token>"

# --- Amazon Bedrock AgentCore Memory ---
# Long-term memory store for genre preferences and remembered picks,
# short-term memory for the active session.
AGENTCORE_MEMORY_ID="mem-xxxxxxxxxxxxxxxxxxxx"
AGENTCORE_MEMORY_ROLE_ARN="arn:aws:iam::123456789012:role/AgentCoreMemoryRole"
